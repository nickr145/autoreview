# === Required ===
ANTHROPIC_API_KEY=
GITHUB_TOKEN=
WANDB_API_KEY=

# === Agent models ===
CLAUDE_AUDITOR_MODEL=claude-sonnet-4-6
CLAUDE_QUALITY_MODEL=claude-sonnet-4-6
CLAUDE_PUBLISHER_MODEL=claude-haiku-4-5

# === Behaviour ===
MAX_ITERATIONS=3
THINKING_BUDGET_TOKENS=8000
THINKING_ENABLED=true
SANDBOX_MEM_LIMIT=512m
LOG_LEVEL=INFO
